{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "slowdoctor-type",
  "main": "worker/build/worker/shim.mjs",
  "compatibility_date": "2026-07-01",
  "build": {
    // skip the 3-4 min source install when worker-build is already present
    // (Workers Builds pre-installs it via cargo-binstall in the Build command)
    "command": "(command -v worker-build >/dev/null || cargo install -q worker-build) && cd worker && worker-build --release"
  },
  "assets": {
    "directory": "web/dist"
  },
  // Single public URL: custom domain only (workers.dev + preview URLs off).
  // Custom domains require zone and worker in the same account (API error 10083) —
  // deploys run via Workers Builds (Git integration) on the account that owns slowdoctor.dev.
  "workers_dev": false,
  "preview_urls": false,
  "routes": [{ "pattern": "type.slowdoctor.dev", "custom_domain": true }],
  "triggers": {
    // 21:00 UTC = 06:00 KST — daily VOA feed refresh
    "crons": ["0 21 * * *"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "slowdoctor-type",
      "database_id": "393706dc-e049-4f48-902f-846df11433de"
    }
  ],
  "observability": {
    "enabled": true
  }
}
